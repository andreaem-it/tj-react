# Copia in .env.local (non committare .env.local).

# Sessione login (min 32 caratteri)
AUTH_SECRET=

ADMIN_USER=
# Hash bcrypt della password admin (o ADMIN_PASSWORD_HASH_B64 se i $ danno problemi)
ADMIN_PASSWORD_HASH=

# Postgres Neon – galleria media admin
DATABASE_URL=

# Cloudflare R2 – upload immagini
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# GA4 Data API + Search Console (dashboard statistiche)
GA4_PROPERTY_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GSC_SITE_URL=

# AdSense Management API — consigliato OAuth (vedi npm run adsense-oauth)
ADSENSE_OAUTH_CLIENT_ID=
ADSENSE_OAUTH_CLIENT_SECRET=
ADSENSE_OAUTH_REFRESH_TOKEN=
# Opzionale se più account: publisher id
ADSENSE_ACCOUNT_ID=
