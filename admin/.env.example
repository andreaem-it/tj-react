# Copia in .env.local (non committare).

# Sessione login (min 32 caratteri)
AUTH_SECRET=

ADMIN_USER=
# Hash bcrypt della password admin (o ADMIN_PASSWORD_HASH_B64 se i $ danno problemi)
ADMIN_PASSWORD_HASH=

# Postgres Neon – galleria media admin
DATABASE_URL=

# Cloudflare R2 – upload immagini
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# GA4 Data API + Search Console + AdSense (dashboard statistiche)
# GA4_PROPERTY_ID=
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_PRIVATE_KEY=
# GSC_SITE_URL=
# Opzionale AdSense: account publisher (es. pub-xxxxxxxxxxxxxxxx)
# ADSENSE_ACCOUNT_ID=
