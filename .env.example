# =============================================================================
# Social stats (follower Facebook / Instagram in homepage)
# =============================================================================
# Per mostrare in automatico i follower nella homepage, crea un file .env.local
# (o .env) e copia qui sotto le variabili con i tuoi valori.
#
# Come ottenere FACEBOOK_ACCESS_TOKEN:
# 1. Vai su https://developers.facebook.com e crea un’app (tipo Business).
# 2. Aggiungi il prodotto "Facebook Login" (e "Instagram Graph API" se usi Instagram).
# 3. Apri https://developers.facebook.com/tools/explorer/
# 4. Seleziona la tua app, aggiungi i permessi: pages_show_list, pages_read_engagement, instagram_basic (obbligatorio per i follower Instagram), business_management (se la pagina è in un portfolio business)
# 5. Genera token e autorizza con l’account admin della pagina techjournal.it.
# 6. In "Endpoint" chiama me/accounts: nella risposta trovi l’access_token della pagina (Page Access Token).
# 7. Usa quel token qui sotto (per produzione preferibile un token a lunga scadenza o System User).
#
# Per Instagram: l’account deve essere Business/Creator, collegato alla pagina in Meta Business Suite, e il token deve avere il permesso instagram_basic.
# Se manca il token, la homepage mostrerà i numeri di fallback (9 Seguono / 38 Followers).
#
# Opzionale: se l'account ha più pagine, scegli quale usare con una delle due variabili sotto.
# FACEBOOK_PAGE_ID=1069683136499195
# FACEBOOK_PAGE_NAME=VedoCompro.it
#
# Se la pagina è in un portfolio business e non compare in me/accounts, imposta l'ID del business
# (lo trovi in "Gestisci e visualizza l'accesso" → Accesso al portfolio business → "Portfolio business (ID: ...)").
# FACEBOOK_BUSINESS_ID=634990590540527
# =============================================================================

FACEBOOK_ACCESS_TOKEN=

# =============================================================================
# Autopost social da WordPress (webhook → Turso + Meta Graph API)
# =============================================================================
# Endpoint: POST https://TUO_DOMINIO/api/webhooks/wp-post-published
# Header obbligatorio: X-TJ-Webhook-Secret (stesso valore di WP_WEBHOOK_SECRET)
# Body JSON: wp_post_id, title, link (https), opzionali excerpt, featured_image_url
#
# Turso: database libsql (idempotenza, niente Neon).
# Non committare mai token; su Vercel → Environment Variables.
#
# Meta: oltre ai permessi per le statistiche, per pubblicare servono tipicamente
# pages_manage_posts (Facebook) e instagram_content_publish (Instagram).
# IG richiede immagine in evidenza HTTPS pubblica (featured_image_url).
# =============================================================================

WP_WEBHOOK_SECRET=
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# =============================================================================
# Google AdSense (sostituisce i banner placeholder)
# =============================================================================
# Dopo l’approvazione del sito in AdSense, crea le unità pubblicitarie nel
# pannello e copia qui l’ID publisher (ca-pub-XXXXXXXX) e gli slot ID.
# Se non imposti queste variabili, restano i placeholder con bordo tratteggiato.
# =============================================================================

NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_ADSENSE_SLOT_HOME_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_HOME_SIDEBAR=
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE_SIDEBAR=
NEXT_PUBLIC_ADSENSE_SLOT_SKYSCRAPER_LEFT=
NEXT_PUBLIC_ADSENSE_SLOT_SKYSCRAPER_RIGHT=
# Modalità test: imposta a "on" per richiedere annunci di test (utile in staging).
# Su localhost la modalità test viene attivata automaticamente.

# NEXT_PUBLIC_ADSENSE_TEST=on

# =============================================================================
# iubenda – Cookie consent (@mep-agency/next-iubenda)
# =============================================================================
# Banner e preferenze cookie gestiti da next-iubenda. Trovi siteId e cookiePolicyId
# in iubenda Dashboard → Il tuo sito → Privacy Controls and Cookie Solution → Embed.
# Se non imposti queste variabili, il banner non viene mostrato.
# =============================================================================

NEXT_PUBLIC_IUBENDA_SITE_ID=
NEXT_PUBLIC_IUBENDA_COOKIE_POLICY_ID=
# Lingua del banner (it, en, es, ...). Default: it
# NEXT_PUBLIC_IUBENDA_LANG=it

# =============================================================================
# Google Analytics 4 (GA4)
# =============================================================================
# Measurement ID (formato G-XXXXXXXXXX) da Google Analytics → Admin → Data Streams.
# Con iubenda: al consenso cookie viene abilitato analytics_storage (Consent Mode v2).
# =============================================================================

NEXT_PUBLIC_GA_MEASUREMENT_ID=

# GA4 Data API (dashboard admin – statistiche). Property ID numerico (GA4 → Admin → Impostazioni proprietà).
# Service account: Google Cloud Console → IAM → Service account → Crea chiave JSON. Email del service account + chiave privata in env.
# GA4: aggiungi l'email del service account come utente della proprietà con ruolo "Visualizzazione".
# GA4_PROPERTY_ID=
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_PRIVATE_KEY=

# Google Search Console (dashboard admin – incrocio con GA4).
# Stesso service account di GA4 (GOOGLE_SERVICE_ACCOUNT_EMAIL + GOOGLE_PRIVATE_KEY).
# 1. In Google Cloud Console abilita "Search Console API" per il progetto.
# 2. In GSC (search.google.com/search-console) aggiungi l'email del service account come utente con accesso in lettura (es. "Restrict" o "Full").
# 3. Imposta GSC_SITE_URL con l’URL della proprietà: URL prefix (es. https://www.techjournal.it/) o Domain (es. sc-domain:techjournal.it).
# GSC_SITE_URL=

# AdSense Management API (dashboard admin – report guadagni e performance).
# Stesso service account di GA4/GSC (GOOGLE_SERVICE_ACCOUNT_EMAIL + GOOGLE_PRIVATE_KEY).
# 1. In Google Cloud Console abilita "AdSense Management API" per il progetto.
# 2. In AdSense: Impostazioni → Accesso e autorizzazione → Aggiungi utente → email del service account con accesso "Solo report".
# 3. Opzionale: ADSENSE_ACCOUNT_ID (solo numero, es. 1234567890). Se non impostato, viene usato il primo account dell'API.
# ADSENSE_ACCOUNT_ID=

# Base per TUTTE le chiamate API dati (WordPress, TechRadar). Usare api.techjournal.it, non www.
# Su Vercel: imposta questa variabile in Project Settings → Environment Variables e rideploya.
# Default: https://api.techjournal.it
NEXT_PUBLIC_API_BASE=https://api.techjournal.it

# URL base API WordPress (plugin tj/v1). Default: NEXT_PUBLIC_API_BASE + /wp-json/tj/v1
# NEXT_PUBLIC_WP_BASE=https://api.techjournal.it/wp-json/tj/v1

# URL base del sito (sitemap, canonical, Open Graph). Default: https://www.techjournal.it
# NEXT_PUBLIC_SITE_URL=https://www.techjournal.it

# Opzionale: verifica proprietà Google Search Console (meta tag google-site-verification)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Immagine servita su /og-default.png (proxy). Consigliato PNG/JPG 1200×630 per Open Graph.
# Senza questa variabile si usa un logo su static.techjournal.it.
# OG_DEFAULT_IMAGE_URL=https://static.techjournal.it/.../og-default-1200x630.png
# NEXT_PUBLIC_OG_DEFAULT_IMAGE_URL= (stesso scopo, leggibile anche dal client se serve)

# URL base API TechRadar (Price Radar, dati live). Default: NEXT_PUBLIC_API_BASE + /techradar/api
# NEXT_PUBLIC_TECHRADAR_API_BASE=https://api.techjournal.it/techradar/api

# Price Radar (sorgenti dati)
# - NEXT_PUBLIC_PRICE_RADAR_ENABLED=true        → usa backend live (PA-API / TechRadar API)
# - NEXT_PUBLIC_PRICE_RADAR_BETA_ENABLED=true   → usa dataset JSON interno (versione Beta)
# Se entrambi sono falsi/assenti, la pagina mostra solo "Coming Soon".
# NEXT_PUBLIC_PRICE_RADAR_ENABLED=true
# NEXT_PUBLIC_PRICE_RADAR_BETA_ENABLED=true

# Opzionale: link alle pagine iubenda (Privacy, Cookie, Termini) per le pagine legali
# NEXT_PUBLIC_IUBENDA_PRIVACY_URL=
# NEXT_PUBLIC_IUBENDA_COOKIE_POLICY_URL=
# NEXT_PUBLIC_IUBENDA_TERMS_URL=

# Email di contatto mostrata in /contatti
# NEXT_PUBLIC_CONTACT_EMAIL=

# =============================================================================
# Brevo – Newsletter (ex Sendinblue)
# =============================================================================
# API Key: Brevo → Impostazioni → Chiavi API → Crea una nuova chiave API.
# Lista: Brevo → Contatti → Liste → crea una lista (es. "Newsletter sito") e
# copia l’ID numerico dall’URL o dalla pagina della lista.
# Senza queste variabili, la route /api/newsletter risponde 503.
# =============================================================================

BREVO_API_KEY=
BREVO_LIST_ID=

# =============================================================================
# Admin – Accesso dashboard /admin (user e password)
# =============================================================================
# Obbligatori per usare /admin. Genera l'hash della password con:
#   node -e "require('bcryptjs').hash('TUA_PASSWORD', 10).then(h=>console.log(h))"
# Poi imposta ADMIN_USER e ADMIN_PASSWORD_HASH. AUTH_SECRET: stringa casuale lunga (es. 32+ caratteri).
# =============================================================================

ADMIN_USER=
# Hash bcrypt. Se i $ nell'hash danno problemi, usa ADMIN_PASSWORD_HASH_B64 (hash in base64):
#   echo -n '$2a$10$il_tuo_hash...' | base64
ADMIN_PASSWORD_HASH=
# ADMIN_PASSWORD_HASH_B64=
AUTH_SECRET=

# =============================================================================
# Cloudflare R2 – Media (galleria, upload articoli)
# =============================================================================
# Struttura path come WordPress: /anno/mese/file. Generate thumb 150x150, small, medium, large, full.
# Dashboard R2 → API Tokens: crea token con permessi lettura/scrittura sul bucket.
# R2_PUBLIC_URL = URL pubblico del bucket (dominio personalizzato o R2 public bucket).
# =============================================================================
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# =============================================================================
# Cloudflare D1 (admin + articoli – parallelamento WordPress)
# =============================================================================
# Usato dalla sezione admin per articoli/categorie. Vedi docs/ADMIN_D1_DESIGN.md.
# Se deploy su Cloudflare Pages: il binding D1 è iniettato da wrangler, non serve qui.
# Se Next.js resta su Vercel e usi D1 via HTTP API (beta):
#   CLOUDFLARE_API_TOKEN=
#   D1_DATABASE_ID=   (UUID del database, da wrangler d1 list)
# =============================================================================
