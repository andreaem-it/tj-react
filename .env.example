# =============================================================================
# Backend (tj-api) — variabili solo sul deploy del backend
# =============================================================================
# Newsletter (Brevo), Meta/social stats, GA4/GSC/AdSense per dashboard, DB, R2,
# webhook WordPress, Turso, ecc. sono configurati in tj-api (.env).
# Documentazione: repo tj-api e .env.example lì.

# =============================================================================
# Frontend (Next — questo progetto)
# =============================================================================

# Obbligatorio per le route /api/* che fanno proxy verso tj-api (articoli, auth,
# analytics, newsletter, price-radar, …). Esempio locale: http://localhost:3003
TJ_API_BASE_URL=

# Chiamate pubbliche read-only dal browser verso tj-api (Price Radar, post, megamenu, social-stats).
# Se omesso o vuoto → fetch su /api/... (proxy Next, stesso origin, niente CORS).
# Se imposti un host (es. https://backend.techjournal.it), su tj-api servono CORS_ORIGINS
# che includano https://www.techjournal.it (vedi tj-api .env.example).
# Produzione consigliata: lasciare vuoto e usare solo il proxy Next, oppure api/backend con CORS sul backend.
NEXT_PUBLIC_TJ_API_BASE_URL=
# NEXT_PUBLIC_TJ_API_BASE_URL=https://api.techjournal.it

# API pubblica articoli / WordPress (default in codice se omesso)
NEXT_PUBLIC_API_BASE=https://api.techjournal.it
# NEXT_PUBLIC_WP_BASE=https://api.techjournal.it/wp-json/tj/v1

# Sito (sitemap, canonical, OG)
# NEXT_PUBLIC_SITE_URL=https://www.techjournal.it

# GA4 lato browser (Measurement ID)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# AdSense — slot e publisher (client)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_ADSENSE_SLOT_HOME_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_HOME_SIDEBAR=
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE_SIDEBAR=
NEXT_PUBLIC_ADSENSE_SLOT_SKYSCRAPER_LEFT=
NEXT_PUBLIC_ADSENSE_SLOT_SKYSCRAPER_RIGHT=
# NEXT_PUBLIC_ADSENSE_TEST=on

# iubenda
NEXT_PUBLIC_IUBENDA_SITE_ID=
NEXT_PUBLIC_IUBENDA_COOKIE_POLICY_ID=
# NEXT_PUBLIC_IUBENDA_LANG=it
# NEXT_PUBLIC_IUBENDA_PRIVACY_URL=
# NEXT_PUBLIC_IUBENDA_COOKIE_POLICY_URL=
# NEXT_PUBLIC_IUBENDA_TERMS_URL=

# TechRadar / Price Radar (feature flag UI)
# NEXT_PUBLIC_PRICE_RADAR_ENABLED=true
# NEXT_PUBLIC_PRICE_RADAR_BETA_ENABLED=true
# NEXT_PUBLIC_PRICE_RADAR_SQLITE_ENABLED=true
# NEXT_PUBLIC_TECHRADAR_API_BASE=https://api.techjournal.it/techradar/api

# Verifica Search Console (meta tag)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# OG default
# OG_DEFAULT_IMAGE_URL=
# NEXT_PUBLIC_OG_DEFAULT_IMAGE_URL=

# Contatti
# NEXT_PUBLIC_CONTACT_EMAIL=

# =============================================================================
# Modulo compatibilità Apple — dati su Neon tramite tj-api (proxy /api/compatibility/* dal browser).
# SSR /compatibility: in ordine TJ_API_BASE_URL, NEXT_PUBLIC_TJ_API_BASE_URL, poi NEXT_PUBLIC_API_BASE
# (lib/constants API_BASE — stesso host delle altre API). Nessun fetch relativo /api dal server.
# =============================================================================

# =============================================================================
# Auth (route /api/* su questo Next se usate; pannello articoli = tj-react-admin; compatibilità: solo tj-react-admin)
# =============================================================================
# Sessione cookie per route protette di questo frontend (se usate).
AUTH_SECRET=

# Stesso segreto di tj-react-admin / tj-api per le route /api/admin/* (proxy verso tj-api).
# PRICE_RADAR_ADMIN_SECRET=
